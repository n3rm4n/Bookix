<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:Bookix.Services"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Bookix.ReadingPage"
             Title="{Binding Title}"
             BackgroundColor="White"
             >

	<Grid>
        <CollectionView
            x:Name="BookListView"
            Margin="15"
            Scrolled="OnBookChunksScrolled"
            ItemSizingStrategy="MeasureAllItems"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10,5" RowDefinitions="Auto">
                        <services:EnhancedLabel Text="{Binding .}"
								   FontSize="18"
								   TextColor="Black"
								   LineBreakMode="WordWrap"
								   VerticalOptions="Start"
								   HorizontalOptions="Fill"
                                   IsTextSelectionEnabled="True"
                                   HorizontalTextAlignment="Start"
                                   >
                            <!--<services:EnhancedLabel.Behaviors>-->
                                <!--<services:TrimLabelSelectionBehavior />-->
                            <!--</services:EnhancedLabel.Behaviors>-->
                        </services:EnhancedLabel>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <ActivityIndicator x:Name="LoadingSpinner"
                           IsRunning="False"
                           IsVisible="False"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Color="Blue" />
	</Grid>
</ContentPage>