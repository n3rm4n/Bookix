<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bookix.Controls.SideMenuControl">

    <Grid>
        <BoxView x:Name="DarkOverlay" Color="Black" Opacity="0" IsVisible="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseMenuTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <Grid x:Name="SideMenuPanel" WidthRequest="300" HorizontalOptions="Start" 
              BackgroundColor="White" TranslationX="-300" RowDefinitions="Auto, *, Auto">

            <!--<StackLayout Grid.Row="0" Padding="20">-->
            <StackLayout Grid.Row="0" Margin="20">
                <HorizontalStackLayout VerticalOptions="Start">
                    <Label Text="Bookix" FontSize="30" FontAttributes="Bold" TextColor="#333" CharacterSpacing="5" FontFamily="PusiaBold" TranslationY="-5" />
                </HorizontalStackLayout>
                
                <BoxView HeightRequest="2" Color="Gray" Margin="0,5,0,10"/>

                <Button Text="Главная" Margin="5,0,5,5" FontAttributes="Bold" Background="DimGrey" CharacterSpacing="1" Clicked="OnOpenMainpageButtonClicked"/>
                <Button Text="Прочитанное" Margin="5,5,5,10" FontAttributes="Bold" Background="DimGrey" CharacterSpacing="1" />
                <BoxView HeightRequest="2" Color="Gray" Margin="0,5,0,10"/>
                <Grid Margin="5,0,5,5">

                    <Border BackgroundColor="DimGrey" 
                            Padding="15,10" 
                            StrokeShape="RoundRectangle 8" 
                            StrokeThickness="0"
                            HorizontalOptions="Fill">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Жанры" 
                                   FontSize="18" 
                                   FontAttributes="Bold" 
                                   TextColor="White" 
                                   VerticalOptions="Center" 
                                   HorizontalOptions="Start"/>
                            <Label x:Name="GenresDropdownButton" 
                                   Grid.Column="1" 
                                   Text="▼" 
                                   FontSize="18" 
                                   TextColor="White" 
                                   Rotation="0"
                                   TranslationY="-2"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <Button BackgroundColor="Transparent" 
                            BorderColor="Transparent"
                            CornerRadius="8"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill"
                            Clicked="OnToggleGenresClicked"/>
                </Grid>

                <StackLayout x:Name="GenresList" IsVisible="False" Margin="15,0,0,10">
                    <Label Text="•  Драмы" Padding="5"/>
                    <Label Text="•  Комедии" Padding="5"/>
                </StackLayout>
            </StackLayout>

            <StackLayout Grid.Row="2" Padding="20">
                <BoxView HeightRequest="2" Color="Gray" Margin="0,0,0,10"/>
                <Button Text="Настройки" Background="DimGrey" CharacterSpacing="1" Margin="5,0,5,0"  FontAttributes="Bold" Clicked="OnOpenSettingsButtonTapped"/>
            </StackLayout>
        </Grid>
    </Grid>
</ContentView>