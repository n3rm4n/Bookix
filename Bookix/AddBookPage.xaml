<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bookix.AddBookPage"
             Title="Добавить книгу">

    <Grid Padding="20">
        <StackLayout Spacing="20">
            <Entry x:Name="AuthorEntry" Placeholder="Имя автора" />
            <Entry x:Name="TitleEntry" Placeholder="Название книги" />
            <Button Text="Установить обложку книги" Clicked="OnChooseBookCover" BackgroundColor="LightGray" TextColor="Black"/>
            <Button Text="Выберите файл .epub или .fb2" Clicked="OnPickFileClicked" BackgroundColor="LightGray" TextColor="Black"/>
            <Image x:Name="CoverPreview" 
       HeightRequest="150" 
       WidthRequest="110" 
       Aspect="AspectFill" 
       HorizontalOptions="Center" 
       IsVisible="False" />
            <Label x:Name="FilePathLabel" Text="Файл не выбран..." FontSize="12" TextColor="Gray" />
        </StackLayout>
        
        <Button Text="Готово"
                HorizontalOptions="End"
                VerticalOptions="End"
                Clicked="OnSaveBookClicked"
                BackgroundColor="Green"
                TextColor="White"/>
    </Grid>
</ContentPage>